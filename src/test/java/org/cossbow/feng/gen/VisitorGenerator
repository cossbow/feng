package org.cossbow.feng.gen;

import io.github.classgraph.ClassGraph;
import io.github.classgraph.ClassInfo;
import org.cossbow.feng.ast.Entity;
import org.junit.jupiter.api.Test;

import java.nio.charset.StandardCharsets;
import java.nio.file.Files;
import java.nio.file.Path;
import java.util.ArrayList;
import java.util.HashSet;
import java.util.List;
import java.util.TreeMap;
import java.util.function.Consumer;

public class VisitorGenerator {

    static class Type implements Comparable<Type> {
        ClassInfo info;
        String pkg;
        String name;
        Type parent;
        List<Type> children = new ArrayList<>();

        @Override
        public int compareTo(Type o) {
            return info.getName().compareTo(o.info.getName());
        }
    }

    void visitType(List<Type> types, Consumer<Type> consumer) {
        for (Type type : types) {
            consumer.accept(type);
            visitType(type.children, consumer);
        }
    }

    @Test
    void genVisitor() throws Exception {
        var packs = new HashSet<String>();
        var types = new TreeMap<String, Type>();
        try (var cg = new ClassGraph().enableAllInfo()
                .acceptPackages("org.cossbow.feng.ast").scan()) {
            for (var ci : cg.getAllClasses()) {
                if (ci.extendsSuperclass(Entity.class)) {
                    var full = ci.getName();
                    var i = full.lastIndexOf('.');
                    var pkg = full.substring(0, i);
                    var name = full.substring(i + 1);
                    var type = types.computeIfAbsent(ci.getName(), n -> new Type());
                    type.pkg = pkg.intern();
                    type.name = name;
                    type.info = ci;
                    packs.add(type.pkg);
                }
            }
        }

        for (var t0 : types.values()) {
            for (var t : types.values()) {
                if (t0 == t) continue;
                if (t.info.getSuperclass() == t0.info) {
                    t0.children.add(t);
                    t.parent = t0;
                }
            }
        }
        var tops = types.values().stream().filter(t -> t.parent == null).toList();


        var sb = new StringBuilder("package org.cossbow.feng.gen;\n\n");
        for (String p : packs) sb.append("import ").append(p).append(".*;\n");
        sb.append("\npublic interface EntityVisitor {\n\n");
        visitType(tops, t -> {
            if (!t.info.isAbstract()) {
                sb.append("\tvoid visit(").append(t.name).append(" e);\n\n");
                return;
            }
            sb.append("\tdefault void visit(").append(t.name).append(" e) {\n");

            sb.append("\t\tswitch (e) {\n");

            for (var c : t.children) {
                sb.append("\t\t\tcase ").append(c.name).append(" ee:\n");
                sb.append("\t\t\t\tvisit(ee);\n");
                sb.append("\t\t\t\tbreak;\n");
            }
            sb.append("\t\t\tcase null, default:\n");
            sb.append("\t\t\t\tthrow new UnsupportedOperationException();\n");

            sb.append("\t\t}\n");

            sb.append("\t}\n\n");
        });
        sb.append("}\n");
        System.out.println(sb);
        Files.write(Path.of("EntityVisitor.java"), List.of(sb), StandardCharsets.UTF_8);
    }


}

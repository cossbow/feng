import std$map m;


func intHashing(n &m$Node`int,int`) int {
    return n.key;
}

func test(n int) {
    var map = m$newHashmap`int,int`(intHashing);
    for(var i=0;i<n;i+=1) {
        map.set(i, i+100);
    }
    if (var r=map.get(-1); r.ok){}
    if (var r=map.get(0); r.ok){}
    if (var r=map.get(1); r.ok){}
    if (var r=map.get(99); r.ok){}
    if (var r=map.get(100); r.ok){}
    if (var r=map.get(101); r.ok){}
}

func main(args [&!#][*!#]byte) {
    test(5);
}

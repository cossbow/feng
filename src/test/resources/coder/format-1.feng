
export
enum CharEncoding {
    ASCII,
    UTF8,
    UTF16,
    UTF32,
}

export
class String (Writable) {
    const value [*#]byte;
    const enc CharEncoding;

    export
    func bytes() [*#]byte {
        return value;
    }

    export
    func write#(w &!Writer) int {
        const v [&#]byte = value;
        if (v==nil) return 0;
        w.write(v);
        return v.length;
    }

    export
    func char(index int) int32 {
        if (CharEncoding.ASCII == enc) {
            const s [&#]uint8 = value;
            return int32(s[index]);
        }

        if (CharEncoding.UTF16 == enc) {
            const s [&#]uint16 = value;
            return int32(s[index]);
        }

        const s [&#]uint32 = value;
        return int32(s[index]);
    }

    export
    func length() int {
        return value.length << enc.id;
    }

    export
    func isEmpty() bool {
        return value.length == 0;
    }

}

export
func make(value [*#]byte, enc CharEncoding) String {
    return {value=value, enc=enc};
}
export
func makeUtf8(value [*#]byte) String {
    return make(value, CharEncoding.UTF8);
}


func newCapacity(cur, need int) int {
    var t = cur + need;
    var g = cur<2^12 ? cur*2 : cur+2^12;
    return t>=g ? t : g;
}

func copy`T`(src [&!#]T, dst [&!]T, len int) {
    var size = dst.length<=len?dst.length:len;
    size = src.length<=len?src.length:len;
    for (var i=0; i<size; i+=1) {
        dst[i] = src[i];
    }
}

export
class BytesBuffer (Writer) {
    var buf [*!]byte;
    var len int;

    func growIfNeed(need int) {
        if (buf==nil) {
            var cap = newCapacity(0, need);
            buf = new([cap]byte);
            return;
        }
        if (len+need < buf.length)
            return;

        var newCap = newCapacity(buf.length, need);
        var nb = new([newCap]byte);
        for (var i=0; i<len; i += 1)
            nb[i] = buf[i];
        buf = nb;
    }

    export
    func write(data [&!#]byte) {
        growIfNeed(data.length);
        var i = len;
        for (b : data) {
            buf[i] = b;
            i += 1;
        }
    }

    export
    func get() ([*!#]byte, int) {
        return (buf, len);
    }

    export
    func copy() [*!#]byte {
        var src = buf;
        var dst = new([len]byte);
        copy`byte`(src, dst, len);
        return src;
    }
}

func test(n int) {
    var b BytesBuffer;
    var s = makeUtf8("feng");
    format(b, "Hello {}!\n", s);
    var r = b.copy();
}

func main(args[&!#][*!#]byte) {
    test(15);
}

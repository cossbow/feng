
class A {
    var id int;
    var cb func();
}

func run() {}

func Task`T`(t T);

func Callable();

func get() func() {
    return run;
}

func myTask(i int) {}

func using1(a,b func()) {
    if (a==b){}
}
func using2(a func(), b Callable) {
    if (a==b){}
}

func Callback(int)bool;

func positive(a int)bool{
    return a > 0;
}

func use1(a Callback) func(int)bool {
    return a;
}
func use2(a func(int)bool) func(int)bool {
    return use1(a);
}
func use3() func(func(int)bool)func(int)bool {
    return use2;
}

func make(id int) *A{
    return new(A,{id=id});
}
func use4(f func(int)*A) {
    var i = f(123).id;
}

class B:A{}
func write(a&A) {
    a.id=123;
}
func use5(f func(a&A)) {
    var b B;
    f(b);
}

class Work`V` {
    var cb Task`V`;
    func start(v V) {
        cb(v);
    }
}
func create`E`(cb Task`E`) *Work`E` {
    return new(Work`E`, {cb=cb});
}


func test(n int) {
    var a1 A = {cb=run};
    var a2 A = {cb=run};
    if (a1 == a2){}
    using1(run,run);
    using2(run,run);
    var t Task`int` = myTask;
    var check = use2(positive);
    var r=check(2);
    use4(make);
    {
        create`int`(myTask).cb(n);
        var cb func(int) = create`int`(myTask).cb;
        cb(n);
        create`int`(myTask).start(n);
    }
    use5(write);
}


func main(args [&!#][*!#]byte) {
    test(5);
}

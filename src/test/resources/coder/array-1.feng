
class A {
    var id int;
    func run(){}
}


func array1() {
    var aa [2]A = [{id=123}];
    aa[0].run();
    const ap1 [&]A = aa;
    ap1[0].run();

    var ar1 [*]A= new([8]A, [{id=123}]);
    ar1[0].run();
    {
        const ap2 [&]A = ar1;
        ap2[0].run();
    }
    ar1=nil;

    {
        var ar2 [*]A= new([7]A, aa);
        ar2[0].run();
    }
    {
        var ar2 [2]*A = [new(A, aa[0])];
        ar2[0].run();
    }
    {
        var ar [*]A = nil;
        ar = new([2]A);
    }
}


func array2() {
    {
        var aa [2]A = [{id=123}];
        const pa &A = aa[0];
        pa.run();
    }
    {
        var aa [2][5]A = [[{id=123}]];
        const pa &A = aa[0][0];
        pa.run();
    }
    {
        var aa [2]*A = [new(A)];
        aa[0].run();
    }
    {
        var aa [2][*]A = [new([4]A, [{id=321}])];
        aa[0][0].run();
    }
}

func array3() {
    var a1 = [][3]int[[1],[2,3],[4,5,6]];
    var a2 = [][2]int[[1],[2,3],[]];
    var a3 = [][3][2]int[[[1],[2,3],[]],[[1],[2,3],[2]],[]];
    var a4 = [][2]float[[1.1],[2.2,3.3],[]];
    var as = [][4]byte ["xx","ggg"];
}

func test(n int) {
    array1();
    array2();
    array3();
}

func main(args [&!#][*!#]byte) {
    test(5);
}

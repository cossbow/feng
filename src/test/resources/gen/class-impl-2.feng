
interface I {
    run();
}
class A (I) {
    var id int;
    func run() {}
}
class B:A{
}
class C:B{
    func run() {}
}

func test(n int) {
    var i1 *I = new(A);
    i1.run(); // A.run
    var i2 *I = new(B);
    i2.run(); // A.run
    var i3 *I = new(C);
    i3.run(); // C.run
    var b *B = new(C);
    b.run(); // C.run
}

func main() int32 {
    test(15);
    return 0;
}

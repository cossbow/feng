export
class Vector {
    var x float;
    var y float;

    #operator add(left,right,sum) {
        sum.x = left.x + right.x;
        sum.y = left.y + right.y;
    }
}

class Node`T` {
    var next *Node`T`;
    var value T;
}
export
class List`T` {
    var head *Node`T`;
    #helper iterator {
        cursor *Node`T`,
        count int;
        initializer() {
            cursor = head;
        }
        condition() {
            cursor != nil
        }
        updater() {
            cursor = cursor.next;
        }
        get(index int, value *Node`T`) {
            index = count;
            value = cursor.value;
        }
    }
}

class Complex final {
    var real,imag float;

    func neg() Complex {
        return {
            real = -real,
            imag = -imag
        };
    }

    func add(c &!#Complex) Complex {
        return {
            real = real + c.real,
            imag = imag + c.imag
        };
    }

    func sub(c &!#Complex) Complex {
        return {
            real = real - c.real,
            imag = imag - c.imag
        };
    }

    func mul(c &!#Complex) Complex {
        return {
            real = real*c.real - imag*c.imag,
            imag = real*c.imag + imag*c.real
        };
    }

    func div(c &!#Complex) Complex {
        var d = c.real*c.real + c.imag* c.imag;
        return {
            real = (real*c.real + imag*c.imag) / d,
            imag = (imag*c.real - real*c.imag) / d
        };
    }

}


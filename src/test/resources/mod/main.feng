import mod$aaa a;
import mod$aab v;
import mod$aac r;
import mod$map m;

func intHashing(k int) int {
    return (k);
}

func testMap(n int) {
    var map = m$newHashmap`int,int`(intHashing);
    for(var i=0;i<n;i+=1) {
        map.set(i, i+100);
    }
    if (var r=map.get(-1); r.ok){}
    if (var r=map.get(0); r.ok){}
    if (var r=map.get(1); r.ok){}
    if (var r=map.get(99); r.ok){}
    if (var r=map.get(100); r.ok){}
    if (var r=map.get(101); r.ok){}
}


func foo(a,b v$Vector) v$Vector {
    return a.sub(b);
}

func test(n int) {
    r$use2(foo);

    a$wrap`int`(123);
    a$make(n);
}

func main(args [&!#][*!#]byte) {
    test(5);
}

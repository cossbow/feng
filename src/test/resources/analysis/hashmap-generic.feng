
class Result`V` final {
    var v V;
    var ok bool;
}

class Node`K, V` final {
    var key K;
    var value V;
    var next *Node`K, V`;
}

class HashMap`K, V` {
    const hashing func(k K) int;
    var buckets [*]*Node`K, V`;
    var size int;
    var threshold int;

    func indexed(k K) int {
        var h = hashing(k);
        return h & (buckets.length-1);
    }

    func rehash() [*]*Node`K, V` {
        if (buckets == nil) {
            buckets = new([16]*Node`K, V`);
        } else if (size < threshold) {
            return buckets;
        } else {
            var cap = buckets.length << 1;
            var newBuck = new([cap]*Node`K, V`);
            for (var i=0; i<buckets.length; i += 1) {
                var cur = buckets[i];
                for (cur != nil) {
                    var next = cur.next;
                    var idx = hashing(cur.key) % cap;
                    cur.next = newBuck[idx];
                    newBuck[idx] = cur;
                    cur = next;
                }
            }
            buckets = newBuck;
        }
        threshold = int(float32(buckets.length) * 0.75);
        return buckets;
    }

    func set(key K, value V) Result`V` {
        var bucks = rehash();
        var idx = indexed(key);
        var cur = bucks[idx];
        if (cur == nil) {
            bucks[idx] = new(Node`K, V`, {key=key,value=value});
            size += 1;
            return {ok=true};
        }

        var prev *Node`K, V` = nil;
        for (cur != nil) {
            if (key == cur.key) {
                var old = cur.value;
                cur.value = value;
                return {v=old};
            }
            prev = cur;
            cur = cur.next;
        }
        prev.next = new(Node`K, V`, {key=key,value=value});

        size += 1;

        return {ok=true};
    }

    func get(key K) Result`V` {

        var idx = indexed(key);
        var cur = buckets[idx];
        if (cur == nil) {
            return {};
        }

        for (cur != nil && cur.key != key) {
            cur = cur.next;
        }
        if (cur == nil) return {};
        return {ok=true, v=cur.value};
    }
}

func newHashmap`K,V`(hashing func(k K)int) *HashMap`K,V` {
    return new(HashMap`K,V`, {hashing=hashing});
}

func intHashing(k int) int {
    return (k);
}

func test(n int) {
    var map = newHashmap`int,int`(intHashing);
    for(var i=0;i<n;i+=1) {
        map.set(i, i+100);
    }
    if (var r=map.get(-1); r.ok){}
    if (var r=map.get(0); r.ok){}
    if (var r=map.get(1); r.ok){}
    if (var r=map.get(99); r.ok){}
    if (var r=map.get(100); r.ok){}
    if (var r=map.get(101); r.ok){}
}

func main(args [&!#][*!#]byte) {
    test(15);
}

export
enum CharEncoding {
    ASCII,
    UTF16,
    UTF32,
}

class String {
    const value [*]uint8;
    const cc CharEncoding;

    func value() [*]uint8 {
        return value;
    }

    func char(index int) int32 {
        if (CharEncoding.ASCII == cc) {
            const s [&]uint8 = value;
            return int32(s[index]);
        }
        const s [&]uint16 = value;
        return int32(s[index]);
    }

    func len() int {
        return value.length << cc.id;
    }

    func isEmpty() bool {
        return value.length == 0;
    }

}


export
enum CharCode {
    ASCII,
    UTF8,
}

class String {
    const value *rom;
    const code CharCode;

    func value() *rom {
        return value;
    }

    func char(index int) int32 {
        if (CharCode.ASCII == code) {
            const s &rom`[]uint8` = value;
            return int32(s[index]);
        }
        const s &rom`[]uint16` = value;
        return int32(s[index]);
    }

    func len() int {
        return value.length << code.id;
    }

    func isEmpty() bool {
        return value.length == 0;
    }

}
